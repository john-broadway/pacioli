# pacioli deploy — one config, four stages (provision -> govern -> perimeter -> instruments).
# Copy to deploy.env next to the stage scripts and fill in. Every stage sources this file.
# Extracted 2026-07-17 from the proven live build (run records: broker/docs/plans/).

# --- the site ---
ERP_SITE=erp.example.lan          # frappe site name; also the Host the TLS door serves
SITE_TZ=UTC                       # set YOUR zone; POSITIVE-READBACK enforced (an empty zone is a trap)
FRAPPE_BRANCH=version-16

# --- the books ---
COMPANY_NAME="Example Family Foundation"
COMPANY_ABBR=EFF
COMPANY_CURRENCY=USD
COMPANY_COUNTRY="United States"

# --- the seat (the broker's ONLY credential; tight by construction) ---
SEAT_USER=pacioli@example.lan

# --- the workflow (separation of duties on Sales Invoice) ---
WORKFLOW_APPROVER_ROLE="Accounts Manager"   # who may Approve; self-approval is OFF

# --- perimeter (stage 3) ---
PROXY_IP=                         # TLS proxy allowed to reach :80 (empty = no :80 allow)
BROKER_HOST_IP=                   # host running the pacioli broker: allowed :8000/:9000/:22
ADMIN_SSH_IPS=                    # space-separated extra :22 allows (e.g. your hypervisor)

# --- guard artifact (stage 2) ---
GUARD_WHEEL=                      # path to a pacioli_guard wheel ON THIS HOST (bench env pip
                                  # installs it; `bench get-app` refuses a bare sdist)
